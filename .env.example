# ============================================
# DocXL AI - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_BASE_URL=https://your-app-url.vercel.app
CORS_ORIGINS=*

# ============================================
# OPENAI (REQUIRED)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ============================================
# SUPABASE (REQUIRED)
# ============================================
# Get these from your Supabase project settings
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# RAZORPAY - INDIA PAYMENTS (REQUIRED)
# ============================================
# Get these from: https://dashboard.razorpay.com/app/keys
# Use test keys for development, live keys for production

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ============================================
# PADDLE - GLOBAL PAYMENTS (OPTIONAL)
# ============================================
# Get these from: https://vendors.paddle.com/authentication
# Required if you want to accept payments outside India

# PADDLE_API_KEY=your_paddle_api_key
# PADDLE_PRICE_ID=pri_01xxxxxxxxxxxxx
# PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret

# ============================================
# CRON PROTECTION (REQUIRED FOR PRODUCTION)
# ============================================
# Generate a random secure string (e.g., openssl rand -hex 32)
# This protects your cron endpoints from unauthorized access

CRON_SECRET=generate-a-random-secure-string-here

# ============================================
# FORMSPREE - CONTACT FORM (OPTIONAL)
# ============================================
# Get a free form ID from: https://formspree.io
# Leave commented if you want to use mailto fallback

# NEXT_PUBLIC_FORMSPREE_FORM_ID=your_form_id_here

# ============================================
# SETUP INSTRUCTIONS
# ============================================
#
# 1. SUPABASE SETUP:
#    - Create a new project at https://supabase.com
#    - Run the SQL schema from /scripts/supabase-schema.sql
#    - Run the migration from /scripts/migration-usage-logs.sql
#    - Create a storage bucket named 'uploads' with public access
#    - Copy your project URL and keys above
#
# 2. OPENAI SETUP:
#    - Sign up at https://platform.openai.com
#    - Add billing information (pay-as-you-go)
#    - Create an API key with gpt-4o access
#    - Copy the key above (starts with sk-proj-)
#
# 3. RAZORPAY SETUP (India):
#    - Sign up at https://razorpay.com
#    - Complete KYC verification
#    - Get your live key_id and key_secret
#    - Create a payment link or use API integration
#
# 4. PADDLE SETUP (Global - Optional):
#    - Sign up at https://paddle.com
#    - Create a product and price (recommended: $9 USD)
#    - Get your Seller ID, API Key, and webhook secret
#    - Configure webhook URL: https://your-app.vercel.app/api/webhooks/paddle
#
# 5. VERCEL DEPLOYMENT:
#    - Import your repo to Vercel
#    - Add all environment variables in Vercel dashboard
#    - For cron jobs, add CRON_SECRET to Vercel environment variables
#    - Deploy!
#
# ============================================
